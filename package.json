{
  "name": "razer",
  "version": "1.0.0",
  "description": "Razer Color-Based Target Detection Tool",
  "main": "electron/main.js",
  "scripts": {
    "dev:vite": "vite --port 5173",
    "dev:electron": "wait-on http://localhost:5173 && electron . --no-sandbox",
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "screenshot-desktop": "^1.12.7",
    "jimp": "^0.22.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.razer.tool",
    "productName": "Razer",
    "directories": { "output": "dist-electron" },
    "win": { "target": "nsis" },
    "files": ["dist/**/*", "electron/**/*", "package.json"]
  }
}
